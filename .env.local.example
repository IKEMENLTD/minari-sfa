# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API
CLAUDE_API_KEY=your-claude-api-key

# Jamroll API
JAMROLL_API_KEY=your-jamroll-api-key

# Google Service Account (JSON文字列)
GOOGLE_SERVICE_ACCOUNT_JSON={}

# Google Drive フォルダID
GOOGLE_DRIVE_FOLDER_ID=your-processed-docs-folder-id
GOOGLE_DRIVE_JAMROLL_FOLDER_ID=your-jamroll-folder-id
GOOGLE_DRIVE_PROUD_FOLDER_ID=your-ploudnote-folder-id

# アプリケーション URL（SSR での内部 API 呼び出しに使用）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# モック切替（true でモック動作）
USE_MOCK=true

# サイトパスワード
SITE_PASSWORD=your-password

# Google Docs共有先メール
GOOGLE_DRIVE_SHARE_EMAIL=your-email@gmail.com

# Google Sheets 顧客管理スプレッドシートID
GOOGLE_SHEET_ID=your-spreadsheet-id

# Renderポート
PORT=10000

# 環境（Renderでは production に設定）
NODE_ENV=development
